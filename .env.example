# Gemini API配置（仅支持 Google 官方 API）
# 如需使用第三方 Gemini 兼容 API，请使用 OpenAI 配置
GEMINI_API_KEY=
GEMINI_OUTLINE_MODEL=gemini-2.5-pro
GEMINI_CONTENT_MODEL=gemini-2.5-flash

# 嵌入模型配置
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_API_BASE=https://api.siliconflow.cn/v1

# 大纲模型配置
OPENAI_OUTLINE_API_KEY=
OPENAI_OUTLINE_API_BASE=https://api.siliconflow.cn/v1
OPENAI_OUTLINE_MODEL=Qwen/Qwen2.5-7B-Instruct
# API 模式: auto (自动检测), chat (Chat Completions API), responses (Responses API)
# - auto: 优先尝试 Responses API，失败后回退到 Chat Completions
# - chat: 强制使用 Chat Completions API（兼容性最好）
# - responses: 强制使用 Responses API（更高效，但部分第三方 API 不支持）
OPENAI_OUTLINE_API_MODE=auto

# 内容模型配置
OPENAI_CONTENT_API_KEY=
OPENAI_CONTENT_API_BASE=https://api.siliconflow.cn/v1
OPENAI_CONTENT_MODEL=Qwen/Qwen2.5-7B-Instruct
# API 模式: auto (自动检测), chat (Chat Completions API), responses (Responses API)
OPENAI_CONTENT_API_MODE=auto

# 超时和重试配置
GEMINI_TIMEOUT=300
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=90
OPENAI_CONTENT_TIMEOUT=180
OPENAI_OUTLINE_TIMEOUT=120
OPENAI_EMBEDDING_TIMEOUT=60
OPENAI_RETRY_DELAY=15

# ==============================================
# 备用模型配置（Fallback）
# ==============================================
# 独立的备用API密钥（当主模型失败时使用）
# 如果不设置，备用功能将自动禁用
# 注意：不要复用嵌入模型的API密钥，应使用独立密钥
FALLBACK_API_KEY=
FALLBACK_API_BASE=https://api.siliconflow.cn/v1